<mxfile host="Electron">
  <diagram id="smart-home-context" name="C4 Context - Smart Home">
    <mxGraphModel dx="2204" dy="1120" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=24;fontColor=#17202A;" value="Контекст новых сервисов Умный дом" vertex="1">
          <mxGeometry height="50" width="740" x="430" y="40" as="geometry" />
        </mxCell>
        <mxCell id="owner" parent="1" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=14;fontColor=#17202A;" value="&lt;b&gt;Собственник&lt;/b&gt;&lt;br&gt;Пользователь мобильного приложения" vertex="1">
          <mxGeometry height="220" width="120" x="70" y="40" as="geometry" />
        </mxCell>
        <mxCell id="pd-system" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#1F77B4;strokeColor=#155A8A;fontColor=#FFFFFF;fontSize=15;spacing=12;" value="&lt;b&gt;PropDevelopment&lt;/b&gt;&lt;br&gt;Сервисы для собственников&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Мобильное приложение, tenant-core-app, CRM собственников, сервис интеграции Умный дом&lt;/font&gt;" vertex="1">
          <mxGeometry height="160" width="330" x="310" y="370" as="geometry" />
        </mxCell>
        <mxCell id="partner" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#8C8496;strokeColor=#736782;fontColor=#FFFFFF;fontSize=15;spacing=12;" value="&lt;b&gt;Платформа партнера Умный дом&lt;/b&gt;&lt;br&gt;Видеодомофон, распознавание лиц, распознавание номеров, управление устройствами&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Внешняя система партнера&lt;/font&gt;" vertex="1">
          <mxGeometry height="160" width="350" x="1180" y="330" as="geometry" />
        </mxCell>
        <mxCell id="intercom" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#E8F2FB;strokeColor=#6EA6D7;fontColor=#17202A;fontSize=13;spacing=10;" value="&lt;b&gt;Интеллектуальный домофон&lt;/b&gt;&lt;br&gt;Звонок, видео, открытие двери, биометрическая идентификация" vertex="1">
          <mxGeometry height="115" width="220" x="1370" y="40" as="geometry" />
        </mxCell>
        <mxCell id="barrier" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#E8F2FB;strokeColor=#6EA6D7;fontColor=#17202A;fontSize=13;spacing=10;" value="&lt;b&gt;Интеллектуальный шлагбаум&lt;/b&gt;&lt;br&gt;Распознавание номера автомобиля и открытие проезда" vertex="1">
          <mxGeometry height="115" width="220" x="1360" y="690" as="geometry" />
        </mxCell>
        <mxCell id="uk" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#F5F5F5;strokeColor=#A0A0A0;fontColor=#17202A;fontSize=13;spacing=10;" value="&lt;b&gt;Управляющая компания&lt;/b&gt;&lt;br&gt;Назначает зоны доступа, управляет жильцами и объектами ЖК" vertex="1">
          <mxGeometry height="110" width="260" x="350" y="765" as="geometry" />
        </mxCell>
        <mxCell id="regulator-note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#FFF3CD;strokeColor=#D6B656;fontColor=#17202A;fontSize=13;align=left;spacing=12;" value="&lt;b&gt;Ключевые границы доверия&lt;/b&gt;&lt;br&gt;1. Собственник входит через приложение PropDevelopment.&lt;br&gt;2. PropDevelopment принимает решение о правах доступа к объекту и передает партнеру только минимальный набор данных.&lt;br&gt;3. Биометрические шаблоны, видео и номера авто обрабатываются партнером по договору и согласию субъекта." vertex="1">
          <mxGeometry height="155" width="490" x="770" y="820" as="geometry" />
        </mxCell>
        <mxCell id="edge-owner-pd" edge="1" parent="1" source="owner" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#17202A;fontSize=12;endArrow=block;" target="pd-system" value="Использует мобильное приложение&lt;br&gt;[HTTPS, OIDC]">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-pd-partner" edge="1" parent="1" source="pd-system" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#17202A;fontSize=12;endArrow=block;" target="partner" value="Команды управления доступом, разрешения, события&lt;br&gt;[REST/gRPC, mTLS, OAuth2 Client Credentials]">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-partner-intercom" edge="1" parent="1" source="partner" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#17202A;fontSize=12;endArrow=block;" target="intercom" value="Управляет устройством&lt;br&gt;и получает события">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-partner-barrier" edge="1" parent="1" source="partner" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#17202A;fontSize=12;endArrow=block;" target="barrier" value="Управляет устройством&lt;br&gt;и получает события">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-uk-pd" edge="1" parent="1" source="uk" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#17202A;fontSize=12;endArrow=block;" target="pd-system" value="Администрирует права доступа&lt;br&gt;по ЖК, дому, подъезду, помещению">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
