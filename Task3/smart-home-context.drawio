        <mxCell id="edge-uk-pd" value="Администрирует права доступа&lt;br&gt;по ЖК, дому, подъезду, помещению" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#17202A;fontSize=12;endArrow=block;" edge="1" parent="1" source="uk" target="pd-system">
