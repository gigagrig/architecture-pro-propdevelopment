        </mxCell>
        <mxCell id="audit" value="&lt;b&gt;SIEM / audit log&lt;/b&gt;&lt;br&gt;Централизованные события ИБ&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Команды открытия, изменения прав, ошибки авторизации, действия партнера&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#F6C85F;strokeColor=#B88916;fontColor=#17202A;fontSize=13;spacing=10;" vertex="1" parent="1">
