        </mxCell>
        <mxCell id="tenant-db" value="&lt;b&gt;tenant-core-db&lt;/b&gt;&lt;br&gt;PostgreSQL&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Данные услуг собственников&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;size=15;fillColor=#1F77B4;strokeColor=#155A8A;fontColor=#FFFFFF;fontSize=13;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="680" y="455" width="230" height="115" as="geometry" />
        </mxCell>
        <mxCell id="crm" value="&lt;b&gt;CRM собственников&lt;/b&gt;&lt;br&gt;Kotlin, Spring Boot&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Проверка собственника, дома, помещения, УК&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#1F77B4;strokeColor=#155A8A;fontColor=#FFFFFF;fontSize=13;spacing=10;" vertex="1" parent="1">
