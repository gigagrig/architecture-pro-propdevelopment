        <mxCell id="owner" value="&lt;b&gt;Собственник&lt;/b&gt;" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=14;fontColor=#17202A;" vertex="1" parent="1">
          <mxGeometry x="70" y="335" width="100" height="180" as="geometry" />
        </mxCell>
        <mxCell id="mobile" value="&lt;b&gt;Витрина сервисов для собственников&lt;/b&gt;&lt;br&gt;Mobile app iOS/Android&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Функции домофона, шлагбаума, управления доступами&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#1F77B4;strokeColor=#155A8A;fontColor=#FFFFFF;fontSize=13;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="330" y="230" width="245" height="125" as="geometry" />
        </mxCell>
        <mxCell id="auth" value="&lt;b&gt;auth-service-1&lt;/b&gt;&lt;br&gt;Keycloak&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;OIDC, MFA/step-up для критичных действий&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#1F77B4;strokeColor=#155A8A;fontColor=#FFFFFF;fontSize=13;spacing=10;" vertex="1" parent="1">
