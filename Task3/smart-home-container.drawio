        </mxCell>
        <mxCell id="tenant" value="&lt;b&gt;tenant-core-app&lt;/b&gt;&lt;br&gt;Kotlin, Spring Boot&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Бизнес-функции для собственников, проверка сессии и маршрутизация команд&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#1F77B4;strokeColor=#155A8A;fontColor=#FFFFFF;fontSize=13;spacing=10;" vertex="1" parent="1">
