        </mxCell>
        <mxCell id="integration" value="&lt;b&gt;smart-home-integration-app&lt;/b&gt;&lt;br&gt;Kotlin, Spring Boot&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Антикоррупционный слой для партнера: авторизация объекта доступа, минимизация данных, rate limit, аудит&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#2E8B57;strokeColor=#1F6B42;fontColor=#FFFFFF;fontSize=13;spacing=10;" vertex="1" parent="1">
